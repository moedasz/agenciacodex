# Copy to .env.local (gitignored) and fill in the values.
# All values exposed to the browser must be prefixed with VITE_.

# Dev server port (optional, defaults to 3001)
PORT=3001

# Google Analytics measurement ID (currently hardcoded in index.html;
# set here if you migrate it to runtime config)
# VITE_GA_MEASUREMENT_ID=

# Facebook Pixel ID (currently hardcoded in index.html)
# VITE_FB_PIXEL_ID=
